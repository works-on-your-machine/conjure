<%= render "shared/header" %>

<div class="px-10 max-w-[960px] mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-4">
      <%= link_to "← Workshop", root_path,
        class: "text-conjure-text-muted text-sm no-underline hover:text-conjure-text transition-colors" %>
      <div>
        <h1 class="font-display text-[28px] font-semibold text-gold m-0">Grimoire Library</h1>
        <p class="text-[13px] text-conjure-text-dim mt-0.5"><%= @grimoires.count %> visual worlds</p>
      </div>
    </div>
    <%= link_to "✦ Create new grimoire", new_grimoire_path,
      class: "bg-gold text-plum-deep px-5 py-2 rounded-md font-body text-[13px] font-medium no-underline shadow-[0_4px_20px_var(--color-gold-glow-strong)]" %>
  </div>

  <div class="grid grid-cols-[repeat(auto-fill,minmax(300px,1fr))] gap-4">
    <% @grimoires.each do |grimoire| %>
      <%= render partial: "grimoires/grimoire_card", locals: { grimoire: grimoire } %>
    <% end %>
  </div>
</div>

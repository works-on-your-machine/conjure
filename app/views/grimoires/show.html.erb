<%= render "shared/header" %>

<div class="px-10 max-w-[720px] mx-auto">
  <div class="flex items-center gap-4 mb-6">
    <%= link_to "← Library", grimoires_path,
      class: "text-conjure-text-muted text-sm no-underline hover:text-conjure-text transition-colors" %>
  </div>

  <h2 class="font-display text-[28px] font-semibold text-gold-light mb-2"><%= @grimoire.name %></h2>
  <p class="text-xs text-conjure-text-dim mb-6">Used in <%= @grimoire.projects_count %> project<%= @grimoire.projects_count == 1 ? "" : "s" %></p>

  <%= render "shared/label", text: "Theme description" %>
  <div class="bg-surface rounded-md border border-conjure-border p-4 text-[13px] text-conjure-text leading-relaxed whitespace-pre-wrap mb-6">
    <%= @grimoire.description %>
  </div>

  <div class="flex gap-2">
    <%= link_to "Edit", edit_grimoire_path(@grimoire),
      class: "bg-surface text-conjure-text-muted px-4 py-2 rounded-md text-[13px] border border-conjure-border no-underline hover:border-conjure-border-hover" %>
    <%= button_to "Delete", grimoire_path(@grimoire), method: :delete,
      class: "bg-transparent text-danger px-4 py-2 rounded-md text-[13px] border border-danger/30 cursor-pointer",
      data: { turbo_confirm: "Delete this grimoire? This cannot be undone." } %>
  </div>
</div>

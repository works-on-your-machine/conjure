<%# Single vision thumbnail — used in wall grid and as Turbo Stream broadcast target %>
<% revealed = local_assigns.fetch(:revealed, true) %>
<div id="vision_<%= vision.id %>"
     data-controller="vision-reveal"
     data-vision-reveal-revealed-value="<%= revealed %>"
     class="relative aspect-video rounded-md overflow-hidden transition-all duration-150
            <%= if vision.selected?
                  'border-2 border-gold shadow-[0_0_24px_var(--color-gold-glow-strong)] scale-[1.02]'
                elsif vision.complete? && vision.image.attached?
                  'border border-white/5 hover:border-gold-dim hover:scale-[1.03] hover:shadow-[0_2px_12px_var(--color-gold-glow)]'
                else
                  'border border-white/5'
                end %>">
  <% if vision.image.attached? %>
    <%= image_tag vision.image, class: "w-full h-full object-cover" %>
  <% else %>
    <div class="w-full h-full flex items-center justify-center <%= (vision.pending? || vision.generating?) ? 'vision-generating' : 'bg-surface-light' %>">
      <% if vision.failed? %>
        <span class="text-xs text-danger">failed</span>
      <% elsif vision.pending? || vision.generating? %>
        <span class="text-xs text-gold font-medium">summoning...</span>
      <% else %>
        <span class="text-xs text-conjure-text-dim"><%= vision.status %></span>
      <% end %>
    </div>
  <% end %>

  <% if vision.selected? %>
    <div class="absolute top-1.5 right-1.5 w-5 h-5 rounded-full bg-gold flex items-center justify-center text-[11px] text-plum-deep font-semibold">
      ✦
    </div>
  <% end %>
</div>

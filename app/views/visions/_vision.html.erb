<%# Single vision thumbnail — used in wall grid and as Turbo Stream broadcast target %>
<div id="vision_<%= vision.id %>"
     class="relative aspect-video rounded-md overflow-hidden transition-all
            <%= vision.selected? ? 'border-2 border-gold shadow-[0_0_24px_var(--color-gold-glow-strong)] scale-[1.02]' : 'border border-white/5 hover:border-conjure-border-hover' %>">
  <% if vision.image.attached? %>
    <%= image_tag vision.image, class: "w-full h-full object-cover" %>
  <% else %>
    <div class="w-full h-full bg-surface-light flex items-center justify-center">
      <% if vision.failed? %>
        <span class="text-xs text-danger">failed</span>
      <% elsif vision.generating? %>
        <span class="text-xs text-gold animate-pulse">generating...</span>
      <% else %>
        <span class="text-xs text-conjure-text-dim"><%= vision.status %></span>
      <% end %>
    </div>
  <% end %>

  <% if vision.selected? %>
    <div class="absolute top-1.5 right-1.5 w-5 h-5 rounded-full bg-gold flex items-center justify-center text-[11px] text-plum-deep font-semibold">
      ✦
    </div>
  <% end %>
</div>

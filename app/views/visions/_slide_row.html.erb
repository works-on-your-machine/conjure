<%# open_slides is a Set of slide IDs whose panels are expanded %>
<% open_slides ||= Set.new %>
<% is_open = open_slides.include?(slide.id) %>
<% selected_vision = slide.visions.find(&:selected?) %>
<% thumbnail_grid_classes = "grid grid-cols-2 gap-3 xl:grid-cols-3 2xl:grid-cols-4" %>

<%= turbo_frame_tag "slide_#{slide.id}_row" do %>
  <div class="mb-6"
       data-controller="slide-panel"
       data-slide-panel-open-value="<%= is_open %>"
       data-slide-panel-project-id-value="<%= project.id %>"
       data-slide-panel-slide-id-value="<%= slide.id %>">
    <%# Slide header %>
    <div class="flex items-center gap-3 mb-2">
      <span class="text-sm text-gold font-semibold"><%= slide.title %></span>
      <% if selected_vision %>
        <span class="text-[11px] text-conjure-text-dim">v<%= selected_vision.position %> chosen</span>
      <% elsif slide.visions.any? %>
        <span class="text-[11px] text-conjure-text-dim">select a vision</span>
      <% end %>
      <% if slide.visions.any? %>
        <button class="text-[11px] text-conjure-text-muted hover:text-conjure-text cursor-pointer bg-transparent border-none"
                data-action="click->slide-panel#toggle"
                data-slide-panel-target="toggleBtn">
          <%= is_open ? "Collapse" : "Show all" %>
        </button>
      <% end %>
    </div>

    <%# === COLLAPSED STATE: just the selected thumbnail (or empty placeholder) === %>
    <div data-slide-panel-target="collapsed" class="<%= is_open ? 'hidden' : '' %>">
      <% if selected_vision %>
        <div class="w-full max-w-[22rem]">
          <button class="w-full p-0 bg-transparent border-none cursor-pointer"
                  data-action="click->slide-panel#toggle">
            <%= render partial: "visions/vision", locals: { vision: selected_vision } %>
          </button>
        </div>
      <% elsif slide.visions.any? %>
        <div class="<%= thumbnail_grid_classes %>">
          <% slide.visions.includes(:conjuring).order(created_at: :desc).each do |vision| %>
            <%= render partial: "visions/vision_tile", locals: { vision: vision, project: project } %>
          <% end %>
        </div>
      <% else %>
        <div class="w-full max-w-[22rem] aspect-video rounded-md border border-dashed border-conjure-border flex items-center justify-center">
          <span class="text-[10px] text-conjure-text-dim">No visions yet</span>
        </div>
      <% end %>
    </div>

    <%# === EXPANDED STATE: detail panel + full thumbnail grid === %>
    <div data-slide-panel-target="expanded" class="<%= is_open ? '' : 'hidden' %>">

      <%# Detail panel for selected vision %>
      <% if selected_vision %>
        <div class="mb-3 p-3 bg-surface rounded-lg border border-gold/20">
          <div class="flex flex-col gap-4 xl:flex-row">
            <div class="w-full max-w-[28rem] xl:shrink-0">
              <div class="relative aspect-video rounded-md overflow-hidden border-2 border-gold shadow-[0_0_24px_var(--color-gold-glow-strong)]">
                <% if selected_vision.image.attached? %>
                  <%= image_tag selected_vision.image, class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full bg-surface-light flex items-center justify-center">
                    <span class="text-xs text-conjure-text-dim"><%= selected_vision.status %></span>
                  </div>
                <% end %>
                <div class="absolute top-1.5 left-1.5 w-5 h-5 rounded-full bg-gold flex items-center justify-center text-[11px] text-plum-deep font-semibold">✦</div>
              </div>
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-[11px] text-conjure-text-dim">Run <%= selected_vision.conjuring_id %> · variation <%= selected_vision.position %></span>
              </div>

              <div class="flex flex-wrap gap-2 mb-3">
                <% if selected_vision.image.attached? %>
                  <button class="bg-surface text-conjure-text-muted px-3 py-1.5 rounded text-[12px] border border-conjure-border cursor-pointer hover:border-conjure-border-hover"
                          data-action="click->gallery-lightbox#openToVision"
                          data-gallery-lightbox-vision-id-param="<%= selected_vision.id %>"
                          data-gallery-lightbox-slide-id-param="<%= slide.id %>">
                    View full screen
                  </button>
                <% end %>
                <%= link_to "✦ Refine",
                  refine_project_path(project, slide_id: slide.id),
                  class: "bg-surface text-conjure-text-muted px-3 py-1.5 rounded text-[12px] border border-conjure-border no-underline hover:border-conjure-border-hover" %>
                <%= button_to "Deselect",
                  project_vision_path(project, selected_vision),
                  method: :patch,
                  params: { vision: { selected: false }, open_slide: slide.id },
                  class: "bg-surface text-conjure-text-muted px-3 py-1.5 rounded text-[12px] border border-conjure-border cursor-pointer hover:border-conjure-border-hover" %>
                <%= button_to "Delete",
                  project_vision_path(project, selected_vision),
                  method: :delete,
                  class: "bg-transparent text-danger px-3 py-1.5 rounded text-[12px] border border-danger/30 cursor-pointer",
                  data: { turbo_confirm: "Delete this vision?" } %>
              </div>

              <details class="text-[12px]">
                <summary class="text-conjure-text-muted cursor-pointer hover:text-conjure-text select-none">Provenance details</summary>
                <div class="mt-2 space-y-2">
                  <div>
                    <span class="text-conjure-text-dim uppercase text-[10px] tracking-wider">Grimoire text</span>
                    <p class="text-conjure-text-muted mt-0.5 whitespace-pre-wrap leading-relaxed max-h-24 overflow-y-auto"><%= selected_vision.conjuring.grimoire_text %></p>
                  </div>
                  <div>
                    <span class="text-conjure-text-dim uppercase text-[10px] tracking-wider">Slide description</span>
                    <p class="text-conjure-text-muted mt-0.5 whitespace-pre-wrap leading-relaxed"><%= selected_vision.slide_text %></p>
                  </div>
                  <div>
                    <span class="text-conjure-text-dim uppercase text-[10px] tracking-wider">Assembled prompt</span>
                    <p class="text-conjure-text-muted mt-0.5 whitespace-pre-wrap leading-relaxed max-h-24 overflow-y-auto"><%= selected_vision.prompt %></p>
                  </div>
                  <% if selected_vision.refinement.present? %>
                    <div>
                      <span class="text-conjure-text-dim uppercase text-[10px] tracking-wider">Refinement</span>
                      <p class="text-conjure-text-muted mt-0.5"><%= selected_vision.refinement %></p>
                    </div>
                  <% end %>
                </div>
              </details>
            </div>
          </div>
        </div>
      <% end %>

      <%# Full thumbnail grid — id is the Turbo Stream broadcast target %>
      <div id="slide_<%= slide.id %>_visions" data-slide-panel-target="grid" class="<%= thumbnail_grid_classes %>">
        <% slide.visions.includes(:conjuring).order(created_at: :desc).each do |vision| %>
          <%= render partial: "visions/vision_tile", locals: { vision: vision, project: project } %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

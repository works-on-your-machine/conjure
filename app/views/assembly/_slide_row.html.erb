<turbo-frame id="assembly_slide_<%= slide.id %>">
  <% selected_vision = slide.visions.find(&:selected?) %>
  <% complete_visions = slide.visions.select { |v| v.complete? && v.image.attached? } %>
  <% pending_visions = slide.visions.select { |v| v.pending? || v.generating? } %>
  <div class="flex gap-4 items-start mb-4">
    <%# Slide number %>
    <div class="w-8 text-right pt-4 shrink-0">
      <span class="text-[13px] text-conjure-text-dim"><%= index + 1 %></span>
    </div>

    <%# Vision image or placeholder %>
    <div class="flex-1 min-w-0">
      <% if pending_visions.any? %>
        <%# Conjuring/refining in progress — show placeholder %>
        <div class="aspect-video rounded-md bg-surface-light flex items-center justify-center">
          <div class="flex items-center gap-2 text-xs text-gold">
            <div class="w-3 h-3 border border-gold-glow border-t-gold rounded-full animate-spin"></div>
            <%= selected_vision ? "Refining..." : "Conjuring..." %>
          </div>
        </div>
      <% elsif selected_vision %>
        <div class="relative">
          <% if selected_vision.image.attached? %>
            <div class="aspect-video rounded-md overflow-hidden">
              <%= image_tag selected_vision.image, class: "w-full h-full object-cover" %>
            </div>
          <% else %>
            <div class="aspect-video rounded-md bg-surface-light flex items-center justify-center">
              <div class="flex items-center gap-2 text-xs text-gold">
                <div class="w-3 h-3 border border-gold-glow border-t-gold rounded-full animate-spin"></div>
                <%= selected_vision.status %>
              </div>
            </div>
          <% end %>
          <%# Refine button %>
          <% if selected_vision.image.attached? %>
            <div class="absolute bottom-2 right-2">
              <button class="px-2.5 py-1 rounded text-[11px] cursor-pointer bg-black/60 text-gold-light border border-conjure-border font-body backdrop-blur-sm"
                      data-action="click->refine-modal#open"
                      data-refine-modal-slide-id-param="<%= slide.id %>"
                      data-refine-modal-slide-title-param="<%= slide.title %>"
                      data-refine-modal-image-url-param="<%= url_for(selected_vision.image) %>"
                      data-refine-modal-source-vision-id-param="<%= selected_vision.id %>"
                      data-refine-modal-redirect-to-param="assembly">
                ✦ Refine
              </button>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="aspect-video rounded-md border border-dashed border-conjure-border flex items-center justify-center">
          <% if complete_visions.empty? %>
            <%= link_to "No vision — #{slide.title}",
              visions_project_path(project),
              class: "text-xs text-conjure-text-dim no-underline hover:text-conjure-text-muted" %>
          <% else %>
            <span class="text-xs text-conjure-text-dim">Select a vision below</span>
          <% end %>
        </div>
      <% end %>

      <%# Thumbnail strip for selecting between visions %>
      <% if complete_visions.size > 1 || (complete_visions.any? && !selected_vision) %>
        <div class="flex gap-1.5 mt-2 overflow-x-auto pb-1">
          <% complete_visions.each do |v| %>
            <%= button_to project_vision_path(project, v),
              method: :patch,
              params: { vision: { selected: true }, return_to: "assembly" },
              class: "shrink-0 w-16 h-9 rounded overflow-hidden border-2 cursor-pointer transition-colors p-0 bg-transparent #{v.selected? ? 'border-gold shadow-[0_0_8px_var(--color-gold-glow)]' : 'border-transparent hover:border-gold-dim'}" do %>
              <%= image_tag v.image, class: "w-full h-full object-cover" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Slide info %>
    <div class="w-[140px] pt-2 shrink-0">
      <div class="text-sm text-conjure-text font-medium"><%= slide.title %></div>
      <% if selected_vision %>
        <div class="text-[11px] text-conjure-text-dim mt-0.5">variation <%= selected_vision.position %></div>
        <% if selected_vision.refinement.present? %>
          <div class="text-[10px] text-gold-dim mt-0.5">refined</div>
        <% end %>
      <% end %>
    </div>
  </div>
</turbo-frame>

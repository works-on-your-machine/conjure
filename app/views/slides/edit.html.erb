<turbo-frame id="slide_editor">
  <%= form_with model: [@project, @slide], class: "space-y-4" do |f| %>
    <%= f.text_field :title,
      class: "w-full font-display text-[22px] font-semibold bg-transparent border-none p-0 pb-3 text-gold-light outline-none" %>

    <%= render "shared/label", text: "What this slide should show" %>
    <%= f.text_area :description, rows: 10,
      placeholder: "Describe what you want this slide to communicate...",
      class: "w-full bg-surface text-conjure-text border border-conjure-border rounded-md p-3 font-body text-[13px] leading-relaxed resize-y outline-none focus:border-conjure-border-hover" %>

    <div class="flex gap-2 flex-wrap items-center">
      <%= f.submit "Save", class: btn_gold %>

      <%= button_to "✦ Conjure vision", project_conjurings_path(@project),
        method: :post,
        params: { scope: "single", slide_id: @slide.id, variations: 1, redirect_to: "incantations" },
        class: "bg-surface text-gold px-4 py-2 rounded-md text-xs border border-gold-dim cursor-pointer hover:bg-gold-glow transition-colors",
        data: { turbo_submits_with: "✦ Summoning..." } %>

      <div class="flex-1"></div>

      <% unless @slide.position == 1 %>
        <%= button_to "↑ Move up", move_project_slide_path(@project, @slide, direction: "up"),
          method: :patch,
          class: "bg-surface text-conjure-text-muted px-3 py-2 rounded-md text-xs border border-conjure-border cursor-pointer" %>
      <% end %>

      <% unless @slide.position == @project.slides.maximum(:position) %>
        <%= button_to "↓ Move down", move_project_slide_path(@project, @slide, direction: "down"),
          method: :patch,
          class: "bg-surface text-conjure-text-muted px-3 py-2 rounded-md text-xs border border-conjure-border cursor-pointer" %>
      <% end %>

      <% vision_count = @slide.visions.size %>
      <%= button_to "Remove", project_slide_path(@project, @slide),
        method: :delete,
        class: btn_danger("text-xs"),
        data: { turbo_confirm: vision_count > 0 ?
          "This slide has #{vision_count} generated #{'vision'.pluralize(vision_count)} that will also be deleted. Continue?" :
          "Remove this slide?" } %>
    </div>
  <% end %>

  <% complete_visions = @slide.visions.select { |v| v.complete? && v.image.attached? } %>
  <% if complete_visions.any? %>
    <div class="mt-6 border-t border-conjure-border pt-5">
      <%= render "shared/label", text: "Generated visions (#{complete_visions.size})" %>
      <div class="grid grid-cols-3 gap-2 mt-2">
        <% complete_visions.each do |vision| %>
          <div class="relative aspect-video rounded-md overflow-hidden border <%= vision.selected? ? 'border-2 border-gold shadow-[0_0_16px_var(--color-gold-glow-strong)]' : 'border-white/5' %>">
            <%= image_tag vision.image, class: "w-full h-full object-cover" %>
            <% if vision.selected? %>
              <div class="absolute top-1 right-1 w-4 h-4 rounded-full bg-gold flex items-center justify-center text-[9px] text-plum-deep font-semibold">✦</div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% pending_visions = @slide.visions.select { |v| v.pending? || v.generating? } %>
  <% if pending_visions.any? %>
    <div class="<%= complete_visions.empty? ? 'mt-6 border-t border-conjure-border pt-5' : 'mt-3' %>">
      <div class="flex items-center gap-2 text-xs text-gold">
        <div class="w-3 h-3 border border-gold-glow border-t-gold rounded-full animate-spin"></div>
        <%= pending_visions.size %> <%= 'vision'.pluralize(pending_visions.size) %> summoning...
      </div>
    </div>
  <% end %>
</turbo-frame>

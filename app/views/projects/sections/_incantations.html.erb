<% active_slide = params[:slide].present? ? @project.slides.find_by(id: params[:slide]) : nil %>
<% active_slide ||= @project.slides.first %>
<div class="flex h-full" data-controller="outline-modal">
  <%# Turbo Stream subscription — page morphs automatically when visions/conjurings change %>
  <%= turbo_stream_from @project %>

  <%# Left pane: slide list %>
  <div class="w-[260px] border-r border-conjure-border p-5 px-3 overflow-y-auto"
       data-controller="slide-list"
       data-slide-list-active-class="bg-gold-glow border-gold-dim [&_.slide-title]:text-gold"
       data-slide-list-inactive-class="border-transparent hover:bg-surface hover:border-conjure-border-hover [&_.slide-title]:text-conjure-text">
    <div class="flex items-center justify-between mb-4 px-1">
      <span class="font-display text-lg font-semibold text-gold-light">Incantations</span>
      <span class="text-[11px] text-conjure-text-dim"><%= @project.slides.size %> slides</span>
    </div>

    <% @project.slides.each do |slide| %>
      <% is_active = slide == active_slide %>
      <%= link_to edit_project_slide_path(@project, slide),
        class: "block p-3 px-3.5 rounded-lg mb-1 transition-all border no-underline #{is_active ? 'bg-gold-glow border-gold-dim' : 'border-transparent hover:bg-surface hover:border-conjure-border-hover'}",
        data: { turbo_frame: "slide_editor", slide_list_target: "item", action: "click->slide-list#select" } do %>
        <%= render partial: "slides/sidebar_entry_content", locals: { slide: slide } %>
      <% end %>
    <% end %>

    <%# Add slide + generate from outline %>
    <div class="mt-3 space-y-2">
      <%= form_with url: project_slides_path(@project), class: "flex gap-1.5" do |f| %>
        <%= f.text_field :title,
          placeholder: "New slide title...",
          class: "flex-1 bg-surface text-conjure-text border border-conjure-border rounded-md px-2.5 py-2 font-body text-xs outline-none focus:border-conjure-border-hover" %>
        <%= f.submit "+",
          class: "bg-surface text-conjure-text-muted px-3 py-2 rounded-md text-xs border border-conjure-border cursor-pointer shrink-0" %>
      <% end %>
      <button class="w-full text-center text-[12px] text-conjure-text-muted bg-transparent border-none cursor-pointer hover:text-gold transition-colors py-1"
              data-action="click->outline-modal#open">
        ✦ Generate from outline
      </button>
    </div>

    <% if @project.outline.present? %>
      <details class="mt-4 pt-3 border-t border-conjure-border">
        <summary class="text-[11px] text-conjure-text-muted cursor-pointer hover:text-conjure-text select-none px-1">Original outline</summary>
        <pre class="mt-2 px-1 text-[11px] text-conjure-text-dim whitespace-pre-wrap font-body leading-relaxed max-h-48 overflow-y-auto"><%= @project.outline %></pre>
      </details>
    <% end %>
  </div>

  <%# Right pane: slide editor (permanent to survive morph) %>
  <div id="slide_editor_pane" class="flex-1 p-8 overflow-y-auto" data-turbo-permanent>
    <% if active_slide %>
      <%= turbo_frame_tag "slide_editor", src: edit_project_slide_path(@project, active_slide) do %>
        <p class="text-[13px] text-conjure-text-dim">Loading...</p>
      <% end %>
    <% else %>
      <turbo-frame id="slide_editor">
        <%= render layout: "shared/empty_state", locals: {
          title: "No incantations yet",
          description: "Each slide is an incantation — a prompt that conjures a vision. Add your first one using the form on the left, or generate slides from an outline."
        } do %>
          <button class="bg-gold text-plum-deep px-5 py-2 rounded-md font-body text-[13px] font-medium cursor-pointer border-none shadow-[0_4px_20px_var(--color-gold-glow-strong)]"
                  data-action="click->outline-modal#open">
            ✦ Generate from outline
          </button>
        <% end %>
      </turbo-frame>
    <% end %>
  </div>

  <%# Outline modal %>
  <div data-outline-modal-target="modal" class="fixed inset-0 bg-black/80 z-50 hidden items-center justify-center p-6">
    <div class="bg-plum-deep rounded-xl border border-conjure-border p-6 w-[600px] max-w-full" data-action="click->outline-modal#stopPropagation">

      <%# Form state %>
      <div data-outline-modal-target="form">
        <h3 class="font-display text-xl text-gold-light mb-1">Generate incantations from outline</h3>
        <p class="text-xs text-conjure-text-muted mb-4">Paste your talk outline, notes, or brain dump. AI will break it into individual slide descriptions.</p>

        <%= form_with url: project_slides_path(@project), method: :post,
          data: { action: "submit->outline-modal#submit" } do |f| %>
          <%= f.text_area :outline, rows: 10,
            placeholder: "Paste your talk outline here...\n\n- Open with the problem\n- Show the key insight\n- Historical context\n- The mechanism\n- Demo\n- What this means for the audience",
            class: "w-full bg-surface text-conjure-text border border-conjure-border rounded-md p-3 font-body text-[13px] leading-relaxed resize-y outline-none focus:border-conjure-border-hover" %>

          <div class="flex gap-2 mt-4 justify-end">
            <button type="button" data-action="click->outline-modal#close"
                    class="bg-surface text-conjure-text-muted px-4 py-2 rounded-md text-[13px] border border-conjure-border cursor-pointer">
              Cancel
            </button>
            <%= f.submit "✦ Generate slides",
              class: "bg-gold text-plum-deep px-5 py-2 rounded-md font-body text-[13px] font-medium cursor-pointer border-none shadow-[0_4px_20px_var(--color-gold-glow-strong)]" %>
          </div>
        <% end %>
      </div>

      <%# Generating state %>
      <div data-outline-modal-target="generating" class="hidden">
        <div class="flex flex-col items-center justify-center py-12 gap-4">
          <div class="w-10 h-10 border-2 border-gold-glow border-t-gold rounded-full animate-spin"></div>
          <p class="font-display text-lg text-gold">Generating incantations...</p>
          <p class="text-xs text-conjure-text-dim">AI is breaking your outline into slides</p>
        </div>
      </div>

    </div>
  </div>
</div>

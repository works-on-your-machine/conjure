<div class="p-8 max-w-[720px]">
  <h2 class="font-display text-[28px] font-semibold text-gold-light mb-1">Grimoire</h2>
  <p class="text-[13px] text-conjure-text-muted mb-6">The visual world for this project</p>

  <%= form_with model: @project, method: :patch, class: "space-y-6" do |f| %>
    <%= render "shared/label", text: "Active grimoire" %>
    <div class="rounded-lg border border-conjure-border bg-surface px-4 py-3">
      <div class="text-[13px] font-medium text-conjure-text"><%= @project.grimoire.name %></div>
      <p class="mt-1 text-xs text-conjure-text-dim">This project edits the grimoire it was created with.</p>
    </div>

    <%= render "shared/label", text: "Theme description" %>
    <%= f.fields_for :grimoire do |grimoire_fields| %>
      <%= grimoire_fields.hidden_field :id %>
      <%= grimoire_fields.text_area :description, rows: 10,
        placeholder: "Describe the world your slides live in.",
        class: "w-full bg-surface text-conjure-text border border-conjure-border rounded-md p-3 font-body text-[13px] leading-relaxed resize-y outline-none focus:border-conjure-border-hover" %>
    <% end %>

    <div class="mt-4">
      <%= render "shared/label", text: "Variations per slide" %>
      <%= f.select :default_variations, [3, 5, 8, 12, 20],
        {}, class: "bg-surface text-conjure-text border border-conjure-border rounded-md px-3 py-2.5 font-body text-[13px] outline-none focus:border-conjure-border-hover" %>
    </div>

    <div class="pt-2">
      <%= f.submit "Save changes", class: btn_gold %>
    </div>
  <% end %>
</div>

<div class="p-8 max-w-[900px] mx-auto" data-controller="refine-modal">
  <%# Turbo Stream subscription — page morphs automatically when visions/conjurings change %>
  <%= turbo_stream_from @project %>

  <%# Header %>
  <% selected_count = @project.slides.count { |s| s.visions.any?(&:selected?) } %>
  <% total = @project.slides.size %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="font-display text-2xl font-semibold text-gold-light m-0">Final cut</h2>
      <p class="text-xs text-conjure-text-dim mt-0.5"><%= selected_count %>/<%= total %> slides selected</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "← Visions", visions_project_path(@project),
        class: "text-conjure-text-muted px-3 py-2 rounded-md text-[13px] no-underline hover:text-conjure-text transition-colors" %>
      <%= link_to "Export images zip", project_export_png_path(@project),
        class: btn_default,
        title: "Import into Figma, Google Slides, Keynote, and similar tools" %>
      <%= link_to "Export project", project_export_project_path(@project), class: btn_default %>
      <%= link_to "Export PDF", project_export_pdf_path(@project),
        class: btn_gold(selected_count < total ? "opacity-40 pointer-events-none" : "") %>
    </div>
  </div>

  <%# Slide rows %>
  <% @project.slides.each_with_index do |slide, index| %>
    <%= render partial: "assembly/slide_row", locals: { slide: slide, project: @project, index: index } %>
  <% end %>

  <%# Refine modal (Stimulus-driven) %>
  <%= render "shared/refine_modal", project: @project %>
</div>

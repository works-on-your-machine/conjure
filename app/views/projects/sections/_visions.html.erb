<div class="p-6">
  <%# Header %>
  <div class="flex items-center justify-between mb-5">
    <div>
      <h2 class="font-display text-2xl font-semibold text-gold-light m-0">Visions</h2>
      <% selected_count = @project.slides.count { |s| s.visions.any?(&:selected?) } %>
      <p class="text-xs text-conjure-text-dim mt-0.5">
        Grimoire: <%= @project.grimoire.name %> — <%= selected_count %>/<%= @project.slides.size %> selected
      </p>
    </div>
    <div class="flex items-center gap-3">
      <% if selected_count > 0 %>
        <%= link_to "View assembly (#{selected_count}/#{@project.slides.size}) →",
          project_path(@project, section: "assembly"),
          class: "bg-gold text-plum-deep px-5 py-2.5 rounded-md font-body text-sm font-semibold no-underline shadow-[0_4px_20px_var(--color-gold-glow-strong)]" %>
      <% end %>
    </div>
  </div>

  <%# Conjure controls %>
  <div class="flex items-center gap-3 mb-6 p-4 bg-surface rounded-lg border border-conjure-border">
    <%= form_with url: project_conjurings_path(@project), method: :post, class: "flex items-center gap-3 w-full" do |f| %>
      <%= f.select :scope, [["All slides", "all"], ["Slides without visions", "empty"]], {},
        class: "bg-plum-deep text-conjure-text border border-conjure-border rounded-md px-3 py-2 font-body text-[13px] outline-none" %>
      <div class="flex-1 text-xs text-conjure-text-dim text-right">
        ~$<%= "%.2f" % (@project.slides.count * @project.default_variations * 0.04) %>
        (<%= @project.slides.count %> slides × <%= @project.default_variations %> var × $0.04)
      </div>
      <%= f.submit "✦ Conjure", class: "bg-gold text-plum-deep px-7 py-3 rounded-md font-display text-base font-semibold tracking-wide cursor-pointer border-none shadow-[0_4px_20px_var(--color-gold-glow-strong)]" %>
    <% end %>
  </div>

  <%# Turbo Stream subscriptions %>
  <%= turbo_stream_from "project_#{@project.id}_visions" %>
  <%= turbo_stream_from "project_#{@project.id}_conjuring" %>

  <%# Slide rows — each in a Turbo Frame for inline updates %>
  <% @project.slides.each do |slide| %>
    <%= render partial: "visions/slide_row", locals: { slide: slide, project: @project } %>
  <% end %>
</div>

<%# Lightbox modal %>
<div id="lightbox-overlay"
     class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-8 cursor-pointer"
     data-controller="lightbox-modal"
     data-action="click->lightbox-modal#close keydown.escape@window->lightbox-modal#close">
  <img data-lightbox-modal-target="image" src="" class="max-w-full max-h-full object-contain rounded-lg" />
</div>

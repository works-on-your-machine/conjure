<div class="p-6" data-controller="gallery-lightbox">
  <%# Header — also replaced via Turbo Stream when selection changes %>
  <%= render partial: "visions/header", locals: { project: @project } %>

  <%# Turbo Stream subscriptions %>
  <%= turbo_stream_from "project_#{@project.id}_visions" %>
  <%= turbo_stream_from "project_#{@project.id}_conjuring" %>

  <%# Slide rows — each in a Turbo Frame for inline updates %>
  <% if @project.slides.any? %>
    <% @project.slides.each do |slide| %>
      <%= render partial: "visions/slide_row", locals: { slide: slide, project: @project } %>
    <% end %>
  <% else %>
    <%= render layout: "shared/empty_state", locals: {
      title: "Add slides first",
      description: "Head to Incantations to write your slide prompts, then come back here to conjure visions."
    } do %>
      <%= link_to "Go to Incantations →", incantations_project_path(@project), class: btn_gold %>
    <% end %>
  <% end %>

  <%# Gallery lightbox overlay %>
  <div data-gallery-lightbox-target="overlay"
       class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center p-8"
       data-action="click->gallery-lightbox#closeOnBackground">

    <%# Left arrow %>
    <button class="absolute left-6 top-1/2 -translate-y-1/2 text-white/40 hover:text-white text-4xl bg-transparent border-none cursor-pointer p-2 transition-colors select-none"
            data-action="click->gallery-lightbox#previous">
      ‹
    </button>

    <%# Center content %>
    <div class="flex flex-col items-center max-w-full max-h-full" data-action="click->gallery-lightbox#stopPropagation">
      <img data-gallery-lightbox-target="image" src="" class="max-w-full max-h-[75vh] object-contain rounded-lg" />

      <div class="mt-3 flex items-center gap-4">
        <span data-gallery-lightbox-target="caption" class="text-sm text-conjure-text-muted"></span>
        <span data-gallery-lightbox-target="counter" class="text-xs text-conjure-text-dim"></span>
      </div>

      <div class="mt-2">
        <button data-gallery-lightbox-target="selectButton"
                data-action="click->gallery-lightbox#toggleSelect"
                class="px-4 py-1.5 rounded-md text-xs border cursor-pointer transition-colors bg-surface text-gold border-gold-dim">
          ✦ Select
        </button>
      </div>
    </div>

    <%# Right arrow %>
    <button class="absolute right-6 top-1/2 -translate-y-1/2 text-white/40 hover:text-white text-4xl bg-transparent border-none cursor-pointer p-2 transition-colors select-none"
            data-action="click->gallery-lightbox#next">
      ›
    </button>
  </div>
</div>

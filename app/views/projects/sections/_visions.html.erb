<div class="p-6">
  <%# Header %>
  <div class="flex items-center justify-between mb-5">
    <div>
      <h2 class="font-display text-2xl font-semibold text-gold-light m-0">Visions</h2>
      <% selected_count = @project.slides.count { |s| s.visions.any?(&:selected?) } %>
      <p class="text-xs text-conjure-text-dim mt-0.5">
        Grimoire: <%= @project.grimoire.name %> — <%= selected_count %>/<%= @project.slides.size %> selected
      </p>
    </div>
    <div class="flex items-center gap-3">
      <% if selected_count > 0 %>
        <%= link_to "View assembly (#{selected_count}/#{@project.slides.size}) →",
          project_path(@project, section: "assembly"),
          class: "bg-gold text-plum-deep px-4 py-2 rounded-md font-body text-[13px] font-medium no-underline shadow-[0_4px_20px_var(--color-gold-glow-strong)]" %>
      <% end %>
    </div>
  </div>

  <%# Conjure controls %>
  <div class="flex items-center gap-3 mb-6 p-4 bg-surface rounded-lg border border-conjure-border">
    <%= form_with url: project_conjurings_path(@project), method: :post, class: "flex items-center gap-3 w-full" do |f| %>
      <%= f.select :scope, [["All slides", "all"], ["Slides without visions", "empty"]], {},
        class: "bg-plum-deep text-conjure-text border border-conjure-border rounded-md px-3 py-2 font-body text-[13px] outline-none" %>
      <div class="flex-1 text-xs text-conjure-text-dim text-right">
        ~$<%= "%.2f" % (@project.slides.count * @project.default_variations * 0.04) %>
        (<%= @project.slides.count %> slides × <%= @project.default_variations %> var × $0.04)
      </div>
      <%= f.submit "✦ Conjure", class: "bg-gold text-plum-deep px-5 py-2 rounded-md font-display text-base font-semibold tracking-wide cursor-pointer border-none shadow-[0_4px_20px_var(--color-gold-glow-strong)]" %>
    <% end %>
  </div>

  <%# Turbo Stream subscription for real-time updates %>
  <%= turbo_stream_from "project_#{@project.id}_visions" %>
  <%= turbo_stream_from "project_#{@project.id}_conjuring" %>

  <%# Slide rows with collapsible visions %>
  <% @project.slides.each do |slide| %>
    <% selected_vision = slide.visions.find(&:selected?) %>
    <% has_visions = slide.visions.any? %>
    <div class="mb-6" data-controller="slide-row" data-slide-row-collapsed-value="<%= selected_vision.present? %>">
      <%# Slide header %>
      <div class="flex items-center gap-3 mb-2">
        <span class="text-[13px] text-gold font-medium"><%= slide.title %></span>
        <% if selected_vision %>
          <span class="text-[11px] text-conjure-text-dim">v<%= selected_vision.position %> chosen</span>
          <button class="text-[11px] text-conjure-text-muted hover:text-conjure-text cursor-pointer bg-transparent border-none"
                  data-action="click->slide-row#toggle"
                  data-slide-row-target="toggleBtn">
            Show all
          </button>
        <% elsif has_visions %>
          <span class="text-[11px] text-conjure-text-dim">select a vision</span>
        <% end %>
      </div>

      <%# Collapsed state: just the selected vision %>
      <% if selected_vision %>
        <div data-slide-row-target="collapsed" class="<%= selected_vision ? '' : 'hidden' %>">
          <div class="w-64 relative">
            <%= link_to project_vision_path(@project, selected_vision), class: "block no-underline" do %>
              <%= render partial: "visions/vision", locals: { vision: selected_vision } %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Expanded state: all visions in a wrapping grid %>
      <div id="slide_<%= slide.id %>_visions"
           data-slide-row-target="expanded"
           class="flex flex-wrap gap-2 <%= selected_vision ? 'hidden' : '' %>">
        <% slide.visions.includes(:conjuring).order(created_at: :desc).each do |vision| %>
          <div class="w-40 relative">
            <%# Conjuring badge %>
            <div class="absolute top-1.5 left-1.5 z-10 bg-plum-deep/80 text-conjure-text-dim text-[10px] px-1.5 py-0.5 rounded backdrop-blur-sm">
              Run <%= vision.conjuring_id %>
            </div>

            <%# Provenance link (click image to view details) %>
            <%= link_to project_vision_path(@project, vision), class: "block no-underline" do %>
              <%= render partial: "visions/vision", locals: { vision: vision } %>
            <% end %>

            <%# Failed vision: show delete button %>
            <% if vision.failed? %>
              <div class="absolute bottom-1.5 right-1.5 z-10">
                <%= button_to project_vision_path(@project, vision), method: :delete,
                  class: "bg-danger/80 text-white text-[10px] px-1.5 py-0.5 rounded cursor-pointer border-none backdrop-blur-sm",
                  data: { turbo_confirm: "Remove this failed vision?" } do %>
                  ✕ Remove
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if slide.visions.empty? %>
          <div class="w-40 aspect-video rounded-md border border-dashed border-conjure-border flex items-center justify-center">
            <span class="text-xs text-conjure-text-dim">No visions yet</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

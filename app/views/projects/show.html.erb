<div class="flex h-screen">
  <%= render "shared/sidebar" %>

  <main class="flex-1 overflow-auto">
    <% section = params[:section] || "grimoire" %>

    <% if section == "grimoire" %>
      <%= render "projects/sections/grimoire" %>
    <% elsif section == "incantations" %>
      <%= render "projects/sections/incantations" %>
    <% elsif section == "visions" %>
      <div class="p-8 text-conjure-text-muted text-sm">Visions section — coming in Epic 08</div>
    <% elsif section == "assembly" %>
      <div class="p-8 text-conjure-text-muted text-sm">Final Cut section — coming in Epic 09</div>
    <% end %>
  </main>
</div>

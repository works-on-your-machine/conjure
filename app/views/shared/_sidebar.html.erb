<%# Project workspace sidebar — expects @project to be set %>
<aside class="w-[200px] border-r border-conjure-border flex flex-col shrink-0">
  <div class="px-4 pt-5 pb-4">
    <%= link_to "← Workshop", root_path,
      class: "text-conjure-text-dim text-xs no-underline hover:text-conjure-text-muted transition-colors" %>
    <div class="font-display text-[15px] font-semibold text-gold-light leading-tight mt-2">
      <%= @project.name %>
    </div>
    <div class="text-xs text-muted mt-0.5">
      ◈ <%= @project.grimoire.name %>
    </div>
  </div>

  <nav class="px-3 py-2 flex-1 border-t border-conjure-border">
    <% sidebar_sections.each do |section| %>
      <%= link_to section_path(@project, section[:id]),
        class: "flex items-center gap-2.5 px-3 py-2.5 rounded-md mb-1 no-underline transition-all #{active_section?(section[:id]) ? 'bg-gold-glow text-gold' : 'text-conjure-text-muted hover:text-conjure-text'}" do %>
        <span class="shrink-0 opacity-80"><%= section[:icon] %></span>
        <span class="text-[13px]"><%= section[:label] %></span>
      <% end %>
    <% end %>
  </nav>

  <div class="px-3 py-4 border-t border-conjure-border"
       data-controller="conjure-cost"
       data-conjure-cost-slides-value="<%= @project.slides.count %>">
    <%= form_with url: project_conjurings_path(@project), method: :post, class: "space-y-3" do |f| %>
      <%= f.hidden_field :scope, value: "all" %>

      <div class="flex items-center justify-between">
        <span class="text-[11px] text-conjure-text-dim uppercase tracking-wider">Variations</span>
        <%= f.select :variations, [3, 5, 8, 12, 20],
          { selected: @project.default_variations },
          class: "bg-plum-deep text-conjure-text border border-conjure-border rounded px-2 py-1 font-body text-xs outline-none focus:border-conjure-border-hover",
          data: { conjure_cost_target: "variations", action: "change->conjure-cost#update" } %>
      </div>

      <div class="text-xs text-conjure-text-dim text-center"
           data-conjure-cost-target="cost">
        <%= @project.slides.count %> slides × <%= @project.default_variations %> var ≈ $<%= "%.2f" % (@project.slides.count * @project.default_variations * 0.08) %>
      </div>

      <%= f.submit "✦ Conjure",
        class: "w-full bg-gold text-plum-deep py-2.5 rounded-md font-display text-base font-semibold tracking-wide cursor-pointer border-none shadow-[0_4px_20px_var(--color-gold-glow-strong)]",
        disabled: @project.slides.empty?,
        data: { turbo_submits_with: "✦ Summoning..." } %>
    <% end %>

    <div class="mt-2" data-controller="reveal-toggle">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" data-reveal-toggle-target="checkbox" data-action="change->reveal-toggle#toggle"
          class="w-3.5 h-3.5 rounded accent-gold cursor-pointer" />
        <span class="text-[11px] text-conjure-text-dim">Summoning effects</span>
      </label>
    </div>
  </div>
</aside>
